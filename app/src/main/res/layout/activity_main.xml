<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    tools:context=".MainActivity">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navegador" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuracion" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grabador" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WebSocket" />
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/pageContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout">

        <LinearLayout
            android:id="@+id/browserPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/urlBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/urlInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="https://example.com"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:maxLines="1" />

                <Button
                    android:id="@+id/btnLoad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Ir" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvServerInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Servidor: iniciando..."
                android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

            <WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/scriptInput"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="8dp"
                android:gravity="top|start"
                android:hint="document.title"
                android:inputType="textMultiLine"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnExecute"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ejecutar JS" />

                <Button
                    android:id="@+id/btnClearLog"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Limpiar log" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="6dp"
                android:background="#101010"
                android:gravity="top|start"
                android:padding="8dp"
                android:scrollbars="vertical"
                android:textColor="#E8E8E8"
                android:textSize="12sp"
                tools:text="[09:00:00] App iniciada" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/configPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvConfigSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Configuracion actual"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvConfigResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Sin ejecuciones"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                <EditText
                    android:id="@+id/dbSoapUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="https://app.bitcode.com.co/datos/WebDatos.asmx"
                    android:inputType="textUri"
                    android:maxLines="1" />

                <EditText
                    android:id="@+id/dbBaseInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Base (ej: AZURE_VPS)"
                    android:inputType="text"
                    android:maxLines="1" />

                <EditText
                    android:id="@+id/dbTokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Token SOAP"
                    android:inputType="text"
                    android:maxLines="1" />

                <EditText
                    android:id="@+id/providerClientTokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Token cliente (WEB_SCRAPING_CLI.TOKEN)"
                    android:inputType="text"
                    android:maxLines="1" />

                <EditText
                    android:id="@+id/providerPasoInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Paso (ORDEN) ej: 1"
                    android:inputType="number"
                    android:maxLines="1" />

                <EditText
                    android:id="@+id/serverPortInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Puerto escucha (REFERENCIA) ej: 32123"
                    android:inputType="number"
                    android:maxLines="1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnConfigSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Guardar config" />

                    <Button
                        android:id="@+id/btnConfigReload"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Recargar config" />
                </LinearLayout>

                <EditText
                    android:id="@+id/dbSqlInput"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    android:gravity="top|start"
                    android:hint="SELECT TOP 1 * FROM [dbx.GENE].dbo.WEB_SCRAPING_CLI"
                    android:inputType="textMultiLine"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnDbFindDataSoap"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FindDataSOAP" />

                    <Button
                        android:id="@+id/btnDbFindReaderSoap"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="FindReaderSOAP" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnProviderLoad"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cargar token" />

                    <Button
                        android:id="@+id/btnServerToggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Iniciar servidor" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/recorderPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvRecorderStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grabador: detenido"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Flujo: inicia grabacion, interactua en la pestana Navegador y deten para generar script." />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRecorderStart"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Iniciar" />

                    <Button
                        android:id="@+id/btnRecorderStop"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Detener" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRecorderClear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Limpiar" />

                    <Button
                        android:id="@+id/btnRecorderApplyToEditor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Pasar a Script" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnRecorderRunNow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Probar script grabado" />

                <EditText
                    android:id="@+id/recorderScriptOutput"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="8dp"
                    android:gravity="top|start"
                    android:hint="Aqui se genera el script android_touch_v1"
                    android:inputType="textMultiLine"
                    android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/websocketPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cliente Drone - Conexion en Tiempo Real"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/wsServerUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Servidor"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:text="https://test1.bitcode.com.co" />

                <EditText
                    android:id="@+id/wsDroneIdInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Drone ID"
                    android:inputType="text"
                    android:maxLines="1"
                    android:text="12345" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnWsConnect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Conectar" />

                    <Button
                        android:id="@+id/btnWsDisconnect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="Desconectar" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWsState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Estado: Desconectado"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWsDroneInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="ID: (no registrado)"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnWsClearLog"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Limpiar log" />

                    <Button
                        android:id="@+id/btnWsUseCurrentToken"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Usar token actual" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWsLog"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="8dp"
                    android:background="#FAFAFA"
                    android:gravity="top|start"
                    android:padding="8dp"
                    android:scrollbars="vertical"
                    android:textColor="#202020"
                    android:textSize="12sp"
                    tools:text="[09:00:00] Registrado como drone 12345" />

                <EditText
                    android:id="@+id/wsStatusPayloadInput"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:layout_marginTop="8dp"
                    android:gravity="top|start"
                    android:hint="{&quot;respuesta&quot;:&quot;ok&quot;}"
                    android:inputType="textMultiLine"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnWsSendStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:enabled="false"
                    android:text="Enviar estado" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <WebView
        android:id="@+id/signalRBridgeWebView"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:importantForAccessibility="no"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
